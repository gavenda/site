{
  "name": "site",
  "version": "1.0.0",
  "scripts": {
    "start": "run-s serve:main",
    "serve:main": "ng serve gavenda-dev",
    "serve:basura": "ng serve basura-gavenda-dev",
    "build:main": "ng build gavenda-dev",
    "build:basura": "ng build basura-gavenda-dev",
    "scully:main": "scully --project gavenda-dev",
    "scully:basura": "scully --project basura-gavenda-dev",
    "generate:main": "run-s build:main scully:main",
    "generate:basura": "run-s build:basura scully:basura",
    "publish:main": "wrangler pages publish dist/static/gavenda-dev/browser --project-name=gavenda",
    "publish:basura": "wrangler pages publish dist/static/basura-gavenda-dev/browser --project-name=basura"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@scullyio/scully": "^2.1.41",
    "@scullyio/scully-plugin-puppeteer": "^2.1.41",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "~21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "wrangler": "^2.21.3"
  }
}